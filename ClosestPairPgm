import java.util.*;
public class ClosestPairPgm {
   public static void main(String[] args) {
      Scanner sc = new Scanner(System.in);
      int n;
      String input;
      String[] parts;
      int x, y;
      List<int[]> coordinates = new ArrayList<>();
      System.out.println("Enter the number of points: ");
      n = sc.nextInt();
      for (int i = 0; i < n; i++) {
         System.out.println("Enter the points (Separated by comma): ");
         input = sc.next();
         parts = input.replace("(", "").replace(")", "").split(",");
         x = Integer.parseInt(parts[0]);
         y = Integer.parseInt(parts[1]);
         coordinates.add(new int[]{x, y});
      }
      ClosestPair cp = new ClosestPair();
      double dist = cp.closestPoints(coordinates);
      System.out.printf("Distance between the closest points is: %.4f%n", dist);
   }
}
