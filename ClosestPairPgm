import java.util.List;
public class ClosestPair {
public double closestPoints(List<int[]> coordinates) {
        int[] p1, p2;
        int[] point1=new int[2];
        int[] point2=new int[2];
        double sqrvalue;
        double d = Double.MAX_VALUE;
        int n = coordinates.size();
        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {
                p1 = coordinates.get(i);
                p2 = coordinates.get(j);
                sqrvalue = Math.sqrt(Math.pow((p1[0] - p2[0]),2)+ Math.pow((p1[1] - p2[1]),2));
                if (sqrvalue < d) {
                    d = sqrvalue;
                    point1=p1;
                    point2=p2;
                }
            }
        }
        System.out.println("The points are ("+point1[0]+","+point1[1]+")"+" and ("+point2[0]+","+point2[1]+")");
        return d;
    }
}
