import java.util.*;
public class StringSearchingPgm {
   public static void main(String[] args) {
      Scanner sc=new Scanner(System.in);
      String[] T;
      String[] P;
      String text,pattern;
      System.out.println("Enter the text: ");
      text=sc.nextLine();
      System.out.println("Enter the pattern: ");
      pattern=sc.nextLine();
      T=text.split("");
      P=pattern.split("");
      int index=0;
      StringSearch s=new StringSearch();
      index=s.StringSearching(T,P);
      if(index!=-1)
         System.out.println("Pattern found first at "+index+".");
      else
         System.out.println("Pattern not found!!!");
   }
}
